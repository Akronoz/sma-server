SMA_API_KEY=cambia-esta-clave-secreta

# ID del gateway RPi conectado por WebSocket (debe coincidir con IOT_GATEWAY_ID en la RPi).
IOT_GATEWAY_ID=default

# Contenedor wg-easy (docker ps). Por defecto wg-easy; cambia si el nombre es otro.
# WG_CONTAINER=wg-easy

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=tu-token-influx
INFLUX_ORG=tu-org
INFLUX_BUCKET=sma

# Persistencia IoT (opcional; por defecto ./data/ dentro del contenedor)
# IOT_COMMANDS_PATH=/app/data/iot_commands.json
# MACHINES_CONFIG_PATH=/app/data/machines_config.json
# IOT_DEVICES_PATH=/app/data/iot_devices.json