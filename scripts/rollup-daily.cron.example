# Rollup diario a las 00:05 (hora del servidor; ajustar TZ si hace falta).
# Ruta típica en el VPS: ~/gironasa/sma-server  (ej. /home/abe/gironasa/sma-server)
# Instalar: crontab -e
5 0 * * * cd /home/abe/gironasa/sma-server && set -a && . ./.env && set +a && /home/abe/gironasa/sma-server/venv/bin/python3 scripts/rollup_daily_energy.py --yesterday >> /home/abe/sma-rollup.log 2>&1

